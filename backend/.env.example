# ──────────────────────────────────────────────────────────────────────────
#  MITS Backend — environment template
#  Copy to .env (dev) or paste each line into Render dashboard env vars (prod)
# ──────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mits?schema=public"

# ── Core auth + runtime ───────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"          # 32+ char hex; Render generates one automatically
SMTP_USER_ENCRYPTION_KEY="another-long-random-string"   # AES-encrypts per-user gmail app pwds + Google refresh tokens
PORT=4000                                               # Render sets this to 10000 internally
CLIENT_ORIGIN="http://localhost:5173"                   # Prod: https://mits-frontend.onrender.com
NODE_ENV=development                                     # Render: production

# ── SMTP (system fallback) ────────────────────────────────────────────────
# Used when a user hasn't configured their own gmail in Settings → My email.
# Gmail setup: enable 2FA → https://myaccount.google.com/apppasswords →
# generate 16-char password (no spaces in env value).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vaibhav.aggarwal@mitssolution.com
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM="MITS Consulting Portal <vaibhav.aggarwal@mitssolution.com>"

# ── Google OAuth + Calendar sync ──────────────────────────────────────────
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JavaScript origin = the backend URL (e.g. https://mits-backend.onrender.com)
# Authorized redirect URI       = <backend>/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/oauth/google/callback
